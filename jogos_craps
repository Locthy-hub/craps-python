import random
import time
import os
from enum import Enum



#  ENUMS


class GamePhase(Enum):
    COME_OUT = "come_out"   # Primeiro rolar — sem point definido
    POINT    = "point"      # Point foi definido, jogador tenta repetir


class RollResult(Enum):
    NATURAL      = "natural"      # 7 ou 11 no come-out → vitória
    CRAPS        = "craps"        # 2, 3 ou 12 no come-out → derrota
    POINT_SET    = "point_set"    # 4,5,6,8,9,10 no come-out → define point
    POINT_HIT    = "point_hit"    # Acertou o point → vitória
    SEVEN_OUT    = "seven_out"    # Tirou 7 após point → derrota
    CONTINUE     = "continue"     # Nenhum resultado decisivo ainda



#  DADOS

class Dice:
    """Representa um par de dados de seis faces."""

    FACES = {
        1: "⚀", 2: "⚁", 3: "⚂",
        4: "⚃", 5: "⚄", 6: "⚅",
    }

    def __init__(self):
        self.die1: int = 0
        self.die2: int = 0

    def roll(self) -> int:
        """Rola os dois dados e retorna a soma."""
        self.die1 = random.randint(1, 6)
        self.die2 = random.randint(1, 6)
        return self.total

    @property
    def total(self) -> int:
        return self.die1 + self.die2

    def display(self) -> str:
        return f"  {self.FACES[self.die1]}  {self.FACES[self.die2]}  →  {self.total}"



#  APOSTAS


class Bet:
    """Representa uma aposta do jogador."""

    PASS_LINE    = "Pass Line"     # Aposta principal: a favor do shooter
    DONT_PASS    = "Don't Pass"    # Aposta contrária ao shooter

    def __init__(self, bet_type: str, amount: float):
        if bet_type not in (self.PASS_LINE, self.DONT_PASS):
            raise ValueError(f"Tipo de aposta inválido: {bet_type}")
        self.bet_type = bet_type
        self.amount   = amount

    def payout(self, won: bool) -> float:
        """Retorna o lucro/prejuízo da aposta (1:1 para Pass Line e Don't Pass)."""
        return self.amount if won else -self.amount

    def __str__(self):
        return f"{self.bet_type}: R${self.amount:.2f}"



#  JOGADOR


class Player:
    """Representa o jogador com saldo e histórico."""

    def __init__(self, name: str, starting_balance: float = 500.0):
        self.name    = name
        self.balance = starting_balance
        self.wins    = 0
        self.losses  = 0
        self.bet: Bet | None = None

    def place_bet(self, bet_type: str, amount: float):
        if amount <= 0:
            raise ValueError("A aposta deve ser maior que zero.")
        if amount > self.balance:
            raise ValueError(f"Saldo insuficiente. Saldo atual: R${self.balance:.2f}")
        self.bet = Bet(bet_type, amount)

    def resolve_bet(self, won: bool):
        """Aplica o resultado da aposta ao saldo."""
        if self.bet is None:
            return
        profit = self.bet.payout(won)
        self.balance += profit
        if won:
            self.wins += 1
        else:
            self.losses += 1
        self.bet = None

    @property
    def stats(self) -> str:
        total = self.wins + self.losses
        pct = (self.wins / total * 100) if total > 0 else 0
        return (
            f"  Vitórias : {self.wins}\n"
            f"  Derrotas : {self.losses}\n"
            f"  Win rate : {pct:.1f}%\n"
            f"  Saldo    : R${self.balance:.2f}"
        )



#  MOTOR DO JOGO


class CrapsGame:
    """Gerencia toda a lógica de uma rodada de Craps."""

    COME_OUT_WIN  = {7, 11}
    COME_OUT_LOSE = {2, 3, 12}
    POINT_NUMBERS = {4, 5, 6, 8, 9, 10}

    def __init__(self, player: Player):
        self.player = player
        self.dice   = Dice()
        self.phase  = GamePhase.COME_OUT
        self.point: int | None = None

    def reset_round(self):
        self.phase = GamePhase.COME_OUT
        self.point = None

    def roll(self) -> tuple[int, RollResult]:
        """Rola os dados e interpreta o resultado conforme a fase atual."""
        total = self.dice.roll()

        if self.phase == GamePhase.COME_OUT:
            if total in self.COME_OUT_WIN:
                result = RollResult.NATURAL
            elif total in self.COME_OUT_LOSE:
                result = RollResult.CRAPS
            else:                          # 4, 5, 6, 8, 9 ou 10
                self.point = total
                self.phase = GamePhase.POINT
                result = RollResult.POINT_SET
        else:  # POINT phase
            if total == self.point:
                result = RollResult.POINT_HIT
            elif total == 7:
                result = RollResult.SEVEN_OUT
            else:
                result = RollResult.CONTINUE

        return total, result

    def resolve(self, result: RollResult) -> bool | None:
        """
        Decide se a aposta foi ganha/perdida.
        Retorna True (ganhou), False (perdeu) ou None (jogo continua).
        """
        pass_line = self.player.bet and self.player.bet.bet_type == Bet.PASS_LINE

        if result == RollResult.NATURAL:
            return True  if pass_line else False
        if result == RollResult.CRAPS:
            return False if pass_line else True
        if result == RollResult.POINT_HIT:
            return True  if pass_line else False
        if result == RollResult.SEVEN_OUT:
            return False if pass_line else True
        return None  # CONTINUE ou POINT_SET → jogo ainda não acabou



#  INTERFACE DE TERMINAL


class Terminal:
    """Helpers de formatação para o terminal."""

    RESET  = "\033[0m"
    BOLD   = "\033[1m"
    GREEN  = "\033[92m"
    RED    = "\033[91m"
    YELLOW = "\033[93m"
    CYAN   = "\033[96m"
    WHITE  = "\033[97m"
    DIM    = "\033[2m"

    @staticmethod
    def clear():
        os.system("cls" if os.name == "nt" else "clear")

    @staticmethod
    def banner():
        print(f"""
{Terminal.YELLOW}╔══════════════════════════════════════════════╗
║       🎲  C R A P S  —  Cassino Python  🎲   ║
╚══════════════════════════════════════════════╝{Terminal.RESET}
""")

    @staticmethod
    def separator():
        print(f"{Terminal.DIM}{'─' * 48}{Terminal.RESET}")

    @staticmethod
    def success(msg: str):
        print(f"\n{Terminal.GREEN}{Terminal.BOLD}✔  {msg}{Terminal.RESET}\n")

    @staticmethod
    def error(msg: str):
        print(f"\n{Terminal.RED}{Terminal.BOLD}✘  {msg}{Terminal.RESET}\n")

    @staticmethod
    def info(msg: str):
        print(f"{Terminal.CYAN}ℹ  {msg}{Terminal.RESET}")

    @staticmethod
    def warn(msg: str):
        print(f"{Terminal.YELLOW}⚠  {msg}{Terminal.RESET}")

    @staticmethod
    def roll_animation(dice: Dice):
        """Animação simples de rolagem."""
        frames = ["🎲 . . .", "🎲 🎲 . .", "🎲 🎲 🎲 ."]
        for frame in frames:
            print(f"\r  {frame}", end="", flush=True)
            time.sleep(0.25)
        print(f"\r{' ' * 20}\r", end="")
        print(f"  {dice.display()}")

