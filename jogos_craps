    @staticmethod
    def input_int(prompt: str, min_val: int, max_val: int) -> int:
        while True:
            try:
                val = int(input(f"{Terminal.WHITE}{prompt}{Terminal.RESET} "))
                if min_val <= val <= max_val:
                    return val
                Terminal.warn(f"Digite um número entre {min_val} e {max_val}.")
            except ValueError:
                Terminal.warn("Entrada inválida. Use apenas números.")

    @staticmethod
    def input_float(prompt: str, min_val: float, max_val: float) -> float:
        while True:
            try:
                val = float(input(f"{Terminal.WHITE}{prompt}{Terminal.RESET} "))
                if min_val <= val <= max_val:
                    return val
                Terminal.warn(f"Valor fora do permitido ({min_val:.2f}–{max_val:.2f}).")
            except ValueError:
                Terminal.warn("Entrada inválida. Use números (ex: 50 ou 50.5).")



#  CONTROLADOR PRINCIPAL
# 

class CrapsController:
    """Orquestra menus, rodadas e fluxo completo do jogo."""

    MIN_BET = 1.0

    def __init__(self):
        self.player: Player | None = None
        self.game:   CrapsGame | None = None

    # ── Setup ──────────────────────────────────

    def setup(self):
        Terminal.clear()
        Terminal.banner()
        name = input(f"{Terminal.WHITE}Seu nome, jogador: {Terminal.RESET}").strip() or "Jogador"
        self.player = Player(name)
        self.game   = CrapsGame(self.player)
        Terminal.success(f"Bem-vindo, {name}! Saldo inicial: R${self.player.balance:.2f}")

    # Escolha de aposta 

    def _choose_bet(self):
        Terminal.separator()
        print(f"\n{Terminal.BOLD}  Tipos de aposta:{Terminal.RESET}")
        print("  1 → Pass Line   (torce pelo 7/11, e pelo point)")
        print("  2 → Don't Pass  (torce pelo 2/3/12, e contra o point)")
        choice = Terminal.input_int("\n  Sua escolha [1-2]:", 1, 2)
        bet_type = Bet.PASS_LINE if choice == 1 else Bet.DONT_PASS

        max_bet = self.player.balance
        amount  = Terminal.input_float(
            f"  Valor da aposta (R$1.00 – R${max_bet:.2f}):",
            self.MIN_BET, max_bet
        )
        self.player.place_bet(bet_type, amount)
        Terminal.info(f"Aposta registrada: {self.player.bet}")

    #  Uma rodada completa 

    def _run_round(self):
        self.game.reset_round()
        self._choose_bet()

        Terminal.separator()
        print(f"\n{Terminal.BOLD}  ── FASE: COME-OUT ──{Terminal.RESET}")

        while True:
            input(f"\n{Terminal.DIM}  [ENTER para rolar]{Terminal.RESET}")
            total, result = self.game.roll()             # agora vem primeiro
            Terminal.roll_animation(self.game.dice)      # e a animação depois 

            self._describe_result(result, total)

            outcome = self.game.resolve(result)

            if outcome is not None:          # rodada terminou
                self.player.resolve_bet(outcome)
                if outcome:
                    Terminal.success(f"Você GANHOU! +R${self.player.bet.amount if self.player.bet else 0:.2f}  →  Saldo: R${self.player.balance:.2f}")
                else:
                    Terminal.error(f"Você PERDEU.  →  Saldo: R${self.player.balance:.2f}")
                break

            if result == RollResult.POINT_SET:
                print(f"\n{Terminal.BOLD}  ── FASE: POINT = {self.game.point} ──{Terminal.RESET}")
                Terminal.info(f"Acerte o {self.game.point} antes do 7 para ganhar.")

    def _describe_result(self, result: RollResult, total: int):
        msgs = {
            RollResult.NATURAL   : f"🎉 Natural! {total} — vitória imediata no come-out!",
            RollResult.CRAPS     : f"💀 Craps!  {total} — derrota imediata no come-out.",
            RollResult.POINT_SET : f"📍 Point definido: {total}",
            RollResult.POINT_HIT : f"🎉 Point atingido! {total} — você ganhou!",
            RollResult.SEVEN_OUT : f"💀 Seven-out! 7 — você perdeu.",
            RollResult.CONTINUE  : f"   {total} — continue rolando...",
        }
        print(f"  {msgs[result]}")

    # ── Menu principal ─────────────────────────

    def _main_menu(self) -> bool:
        """Retorna False quando o jogador decide sair."""
        Terminal.separator()
        print(f"\n{Terminal.BOLD}  O que deseja fazer?{Terminal.RESET}")
        print("  1 → Nova rodada")
        print("  2 → Ver estatísticas")
        print("  3 → Regras rápidas")
        print("  0 → Sair")

        choice = Terminal.input_int("  Escolha:", 0, 3)

        if choice == 1:
            return True
        if choice == 2:
            self._show_stats()
            return True
        if choice == 3:
            self._show_rules()
            return True
        return False  # sair

    def _show_stats(self):
        Terminal.separator()
        print(f"\n{Terminal.BOLD}  📊 Estatísticas de {self.player.name}:{Terminal.RESET}")
        print(self.player.stats)

    def _show_rules(self):
        Terminal.separator()
        print(f"""
{Terminal.BOLD}  📜 REGRAS DO CRAPS (simplificado){Terminal.RESET}

  {Terminal.CYAN}FASE COME-OUT (primeiro rolar){Terminal.RESET}
    7 ou 11  →  Pass Line ganha  /  Don't Pass perde
    2, 3 ou 12 →  Pass Line perde  /  Don't Pass ganha
    4,5,6,8,9,10 → define o POINT, passa para a fase seguinte

  {Terminal.CYAN}FASE POINT{Terminal.RESET}
    Repetir o POINT  →  Pass Line ganha  /  Don't Pass perde
    Tirar 7          →  Pass Line perde  /  Don't Pass ganha
    Qualquer outro   →  continua rolando

  {Terminal.CYAN}PAGAMENTO{Terminal.RESET}
    Pass Line e Don't Pass pagam 1:1
""")

    # ── Encerramento ───────────────────────────

    def _farewell(self):
        Terminal.separator()
        print(f"\n{Terminal.BOLD}  Obrigado por jogar, {self.player.name}!{Terminal.RESET}")
        print(self.player.stats)
        profit = self.player.balance - 500.0
        color  = Terminal.GREEN if profit >= 0 else Terminal.RED
        sign   = "+" if profit >= 0 else ""
        print(f"\n  Resultado final: {color}{sign}R${profit:.2f}{Terminal.RESET}\n")

    # ── Ponto de entrada ───────────────────────

    def run(self):
        Terminal.intro()
        self.setup()

        while True:
            if self.player.balance < self.MIN_BET:
                Terminal.error("Saldo insuficiente para apostar. Fim de jogo!")
                break

            if not self._main_menu():
                break

            # Apenas continua se o jogador escolheu "Nova rodada"
            try:
                self._run_round()
            except KeyboardInterrupt:
                print("\n")
                break

        self._farewell()


# ─────────────────────────────────────────────
#  ENTRY POINT
# ─────────────────────────────────────────────

if __name__ == "__main__":
    CrapsController().run()